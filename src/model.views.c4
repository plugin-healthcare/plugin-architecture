views {
  view index {
    title 'PLUGIN'
    include data-gebruiker, data-houder, -> plugin
  }

  view ph of plugin.ph {
    title 'Processing Hub'
    include *
  }

  view datastation of plugin.datastation {
    title 'Datastation'
    include *
    include -> *
  }

  view dagster {
    title 'Dagster'
    include dagster.*
  }
}
